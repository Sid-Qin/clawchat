{
  "name": "@claw-os/clawchat",
  "version": "0.3.0",
  "type": "module",
  "description": "ClawChat channel plugin for OpenClaw",
  "license": "MIT",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "clawchat": "bin/clawchat.mjs"
